class Solution {
    public String longestCommonPrefix(String[] strs) {

        String soln = "";

        for (int i = 0; i < strs[0].length(); i++) {

            char chr = strs[0].charAt(i);

            for (int j = 1; j < strs.length; j++) {

                if (i >= strs[j].length() || strs[j].charAt(i) != chr) {
                    return soln;
                }
            }

            soln = soln + chr;
        }

        return soln;
    }
}
