class Solution {
    public double findMaxAverage(int[] nums, int k) {

        int s = 0;

        for (int i = 0; i < k; i++) {
            s += nums[i];
        }

        int maxSum = s;

        for (int i = k; i < nums.length; i++) {
            s = s - nums[i - k];
            s = s + nums[i];

            if (s > maxSum) {
                maxSum = s;
            }
        }

        return (double) maxSum / k;
    }
}
