class Solution {
    public int diagonalSum(int[][] mat) {
        int s = 0;
        int n = mat.length;

        for (int i = 0; i < mat.length; i++) {
            s = s + mat[i][i];
            s = s + mat[i][n - 1 - i];
        }

        if (n % 2 == 1)
            s = s - mat[n / 2][n / 2];

        return s;
    }
}
